# Copy to .env and adjust.
# Colab self-host: no external API keys required. Pipeline uses PaddleOCR + pix2tex on Colab.

# --- Pipeline ---
DPI=200

# --- Colab / GPU (self-hosted) ---
USE_GPU=1
VRAM_LIMIT_GB=16

# --- Model toggles (1/0 or true/false) ---
ENABLE_PADDLE_OCR=1
ENABLE_PIX2TEX=1

# --- Colab model API: mô hình chạy trên Colab, ngrok trả ra URL → main.py gọi URL này ---
# Trên Colab: python -m bao.colab_server → in ra BAO_COLAB_URL. Copy URL vào đây để main (local) gửi ảnh lên Colab.
# BAO_COLAB_URL=https://xxxx.ngrok-free.app

# --- Colab env sync: main (load_env) fetches .env from this URL when running on Colab ---
# Chạy local: python -m bao.colab_setup → script in ra 2 dòng, copy vào đây.
# COLAB_ENV_URL=https://xxxx.ngrok-free.app/env
# NGROK_TOKEN=your-ngrok-token
